# 周杰倫輿情監控系統 環境變數設定

# Gemini API Key（用於 LLM 分析）
GEMINI_API_KEY=your_gemini_api_key_here

# Tavily API Key (用於高階 AI 搜尋)
TAVILY_API_KEY=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

# Line Notify Token（用於 Line 推播通知）
LINE_NOTIFY_TOKEN=your_line_notify_token_here

# Telegram Bot Token 和 Chat ID（用於 Telegram 推播通知）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# 伺服器 Port
PORT=3000

# 排程時間（Cron 格式，預設每日早上 9:00）
CRON_SCHEDULE=0 9 * * *
